  comment: 'Schematic in PDF format'
  type: pdf_sch_print
  dir: 'Schematic'
  category: 'Schematic'
  options:
    background_color: false
    color_theme: 'Altium_Theme'
    default_font: 'Times New Roman'

definitions:
  NAME: pdf_schematic
  COMMENT: Schematic in PDF format
  COLOR_THEME: Altium_Theme
  DEFAULT_FONT: Times New Roman
  DIR: Schematic (kibot - config_reader.py:686)
